{
  "name": "hidrocultivo-web",
  "version": "1.0.0",
  "description": "",
  "main": "service-worker.js",
  "scripts": {
    "test": "node --test \"tests/*.test.mjs\"",
    "www:sync": "node scripts/sync-www.cjs",
    "cap:bundle": "node scripts/bundle-capacitor.cjs",
    "cap:prep": "node scripts/sync-www.cjs && node scripts/bundle-capacitor.cjs",
    "cap:sync": "node scripts/sync-www.cjs && node scripts/bundle-capacitor.cjs && npx cap sync",
    "cap:open:android": "npx cap open android",
    "cap:open:ios": "npx cap open ios",
    "rpi:memoria": "node scripts/generate-registro-pdf.js && node scripts/generate-registro-pdf-imprimible.js",
    "rpi:deposito": "node scripts/prepare-rpi-deposit.mjs",
    "rpi:serve": "npx --yes serve . -l 5173",
    "rpi:capturas-check": "node scripts/rpi-check-capturas.mjs",
    "rpi:capturas-abrir": "node scripts/rpi-open-capturas-folder.mjs",
    "rpi:zip": "node scripts/rpi-zip-deposit.mjs",
    "rpi:portada": "node scripts/generate-rpi-portada.js",
    "rpi:fuente": "node scripts/rpi-fuente-zip.mjs"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "overrides": {
    "tar": "^7.5.13",
    "@capacitor/cli": {
      "tar": "6.2.1"
    }
  },
  "devDependencies": {
    "@capacitor/android": "^6.2.0",
    "@capacitor/cli": "^6.2.0",
    "@capacitor/core": "^6.2.0",
    "@capacitor/filesystem": "^6.0.2",
    "@capacitor/ios": "^6.2.0",
    "@capacitor/share": "^6.0.2",
    "esbuild": "^0.25.12"
  },
  "dependencies": {
    "@capgo/capacitor-native-biometric": "^6.0.4",
    "pdfkit": "^0.18.0"
  }
